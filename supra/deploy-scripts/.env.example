# Copy to .env and fill in. .env is gitignored at repo root.
# DEPLOYER_KEY = ed25519 private key (hex, with 0x prefix) for the wallet that submits txs.
# For mainnet: should be one of the multisig owners (0x0047 used in the canonical deploy).
# For testnet: any wallet with testnet SUPRA.
DEPLOYER_KEY=0x<your-32-byte-ed25519-private-key-hex>
